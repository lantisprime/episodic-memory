{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://episodic-memory/plugins/manifest.schema.json",
  "title": "Per-plugin manifest meta-schema (RFC-008 M2, M3-M6, M4b, M5c, R8 typed+versioned)",
  "description": "plugins/<harness>/manifest.json — the enforcement-plugin descriptor (R8 typed-registry, RFC-008 L116; `type` const enforcement). additionalProperties:false at every level; closed enums for harness, event keys, capability tiers, classifier mode, invocation modality. Carries a REQUIRED semver `schema_version` (R8 versioned-contract, RFC-008 L118) declaring the CONTRACT version this manifest is written against — distinct from `version`, which is this plugin's OWN release version. `schema_version` is a semver PATTERN, not a pinned const, so a newer same-major validator reads older manifests (backward); a manifest whose version exceeds the validator max — MAJOR OR MINOR — fails closed at P1. Vocabulary closure, taxonomy/events version equality, and capability honesty are validate-plugin-registry.mjs (P1) checks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "schema_version",
    "id",
    "harness",
    "version",
    "invocation_modality",
    "capabilities",
    "classifier",
    "taxonomy_ref",
    "taxonomy_version",
    "events_version",
    "event_translations",
    "runbook"
  ],
  "properties": {
    "type": { "const": "enforcement" },
    "schema_version": { "$ref": "#/$defs/semver" },
    "id": { "$ref": "#/$defs/harnessId" },
    "harness": { "$ref": "#/$defs/harnessId" },
    "version": { "$ref": "#/$defs/semver" },
    "invocation_modality": { "type": "string", "enum": ["cli", "agent", "api", "static-rules"] },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "pre_tool_use": { "$ref": "#/$defs/tier" },
        "tool_result": { "$ref": "#/$defs/tier" },
        "stop": { "$ref": "#/$defs/tier" },
        "session_start": { "$ref": "#/$defs/tier" },
        "session_end": { "$ref": "#/$defs/tier" }
      }
    },
    "classifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "emits_labels"],
      "properties": {
        "mode": { "type": "string", "enum": ["default", "override"] },
        "emits_labels": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/labelId" }
        },
        "override_path": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mode": { "const": "override" } },
            "required": ["mode"]
          },
          "then": { "required": ["override_path"] },
          "else": { "not": { "required": ["override_path"] } }
        }
      ]
    },
    "taxonomy_ref": { "type": "string", "const": "patterns/taxonomy.json" },
    "taxonomy_version": { "$ref": "#/$defs/sha256Version" },
    "events_version": { "$ref": "#/$defs/sha256Version" },
    "event_translations": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[a-z][a-z0-9_]*$" },
      "additionalProperties": { "$ref": "#/$defs/eventTranslation" }
    },
    "runbook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full", "quickref"],
      "properties": {
        "full": { "type": "string", "minLength": 1 },
        "quickref": { "type": "string", "minLength": 1 }
      }
    },
    "installed_state": {
      "type": "object",
      "description": "Optional (M9). When present, validated against installed-state.schema.json by validate-plugin-registry.mjs."
    }
  },
  "$defs": {
    "harnessId": {
      "type": "string",
      "enum": ["claude-code", "opencode", "codex", "pi-agent", "cursor", "windsurf"]
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "sha256Version": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "tier": {
      "type": "string",
      "enum": ["STRONG", "MEDIUM", "WEAK", "TBD"]
    },
    "labelId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "eventTranslation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_format", "field_bindings"],
      "properties": {
        "source_format": { "type": "string", "minLength": 1 },
        "field_bindings": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
