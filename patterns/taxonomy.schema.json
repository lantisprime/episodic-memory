{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://episodic-memory/patterns/taxonomy.schema.json",
  "title": "Canonical command-classification taxonomy (RFC-008 R3, R4)",
  "description": "Meta-schema for patterns/taxonomy.json — the single source of truth for the 7 canonical labels, their per-gate allow/block actions, and overridability. F1-F10 normative contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "labels", "non_overridable"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Editorial semver of the taxonomy document (distinct from the taxonomy_version sha256 hash carried by contracts/manifests)."
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/label" }
    },
    "non_overridable": {
      "type": "array",
      "description": "Derived convenience list — labels.filter(l => !l.overridable).map(l => l.id), sorted. validate-bp-contract.mjs (P2) asserts equality with the derived set (F9, Rule 14).",
      "items": { "$ref": "#/$defs/labelId" }
    },
    "non_overridable_rationale": {
      "type": "object",
      "description": "Human-readable rationale keyed by non-overridable label id.",
      "additionalProperties": { "type": "string", "minLength": 1 },
      "propertyNames": { "$ref": "#/$defs/labelId" }
    }
  },
  "$defs": {
    "labelId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "gateAction": {
      "type": "string",
      "enum": ["allow", "block"]
    },
    "label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "meaning", "overridable", "gates"],
      "properties": {
        "id": { "$ref": "#/$defs/labelId" },
        "meaning": { "type": "string", "minLength": 1 },
        "overridable": { "type": "boolean" },
        "gates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plan_approval", "pre_checkpoint", "post_checkpoint"],
          "properties": {
            "plan_approval": { "$ref": "#/$defs/gateAction" },
            "pre_checkpoint": { "$ref": "#/$defs/gateAction" },
            "post_checkpoint": { "$ref": "#/$defs/gateAction" }
          }
        }
      }
    }
  }
}
