{
  "_note": "RFC-008 v11.8 detection-layer attribution for the golden corpus. P0 STAGES every fixture but detects only the failures expressible in pure JSON-Schema 2020-12; the rest are owned by later validators. _detected_by marks the layer that semantically owns each failure so the corpus never implies P0 catches a failure only a later layer can.",
  "_routing_note": "P1b (R0c) routing fields, consumed by tests/test-plugin-registry.mjs: `target_schema` = which P0 schema the fixture is shaped as (manifest|_index|structured-alert|bypass_known); `inject` = how the corpus runner feeds it (schema=validate directly vs target_schema; manifest|index|bypass-known=inject into validate-plugin-registry; symlink-temp=temp-dir symlink plant; deferred=p3, recorded NOT run); `attributed_check`/`attributed_reason` = the M-check (and reason code) that MUST appear in violations for a p1 fail-fixture (the F1 'fails at the ATTRIBUTED check, not merely non-zero' stop-rule).",
  "detected_by_vocabulary": ["p0-schema", "p1-registry-validator", "p2-cross-file-validator", "p3-runtime"],
  "current_schema_version": {
    "_note": "CURRENT_SCHEMA_VERSION — single P0 oracle (R8 versioned-contract, RFC-008 L118). Every fixture INSTANCE declaring schema_version MUST byte-equal this value; test-p0-schemas.mjs asserts that equality non-vacuously (>=1 manifest instance). P1 promotes this to a production constant (validate-plugin-registry.mjs MAX_SUPPORTED) byte-equal'd against this oracle, and adds a non-vacuous REGISTRY-instance assertion once plugins/_index.json exists. RFC-009 P2-S6 MINOR bump 1.0.0->1.1.0: registry gains the `activation` plugin type. RFC-012 P2-S3 MINOR bump 1.1.0->1.2.0: registry gains the `learning` plugin type.",
    "value": "1.2.0"
  },
  "hash_serialization_contract": {
    "_note": "Canonical serialization used to bake good-manifest.json's taxonomy_version/events_version (F8/F37). P2's scripts/validate-bp-contract.mjs MUST reuse these exact bytes to avoid two-hand-rolled-hash drift.",
    "taxonomy_version": {
      "input": "patterns/taxonomy.json -> labels",
      "transform": "labels.slice().sort((a,b) => a.id < b.id ? -1 : a.id > b.id ? 1 : 0)",
      "serialize": "JSON.stringify(sortedLabels) with no whitespace; object key order preserved from source (parse -> re-stringify is byte-stable)",
      "digest": "'sha256:' + sha256hex(serialized)",
      "value": "sha256:7ea41ed82edef968baee6880f040008080afd962fec9120336ee336796013cc4",
      "helper": "scripts/lib/version-hash.mjs#taxonomyVersion (promoted from tests/lib/ in P1b; tests/lib/ is a re-export shim)"
    },
    "events_version": {
      "input": "patterns/events.json -> events",
      "transform": "events.slice().sort(byId)",
      "serialize": "JSON.stringify(sortedEvents) with no whitespace",
      "digest": "'sha256:' + sha256hex(serialized)",
      "value": "sha256:13f01e5a599272b349eabd66694b7898e68438e8aad6497e80a9b780bea34ab0",
      "helper": "scripts/lib/version-hash.mjs#eventsVersion"
    }
  },
